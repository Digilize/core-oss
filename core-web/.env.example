# ==============================================================================
# Core Web — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values.
# Only VITE_-prefixed variables are exposed to the browser.
# ==============================================================================

# ------------------------------------------------------------------------------
# [REQUIRED] API Backend
# ------------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000/api

# ------------------------------------------------------------------------------
# [REQUIRED] Auth Service (better-auth / core-auth)
# ------------------------------------------------------------------------------
VITE_AUTH_URL=http://localhost:3001

# ------------------------------------------------------------------------------
# [OPTIONAL] Supabase — only needed for Realtime features (deferred)
# ------------------------------------------------------------------------------
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# ------------------------------------------------------------------------------
# [OPTIONAL] Sentry — Error Tracking
# ------------------------------------------------------------------------------
# Disabled if empty (no errors sent, app works normally)
VITE_SENTRY_DSN=

# ------------------------------------------------------------------------------
# [OPTIONAL] PostHog — Analytics
# ------------------------------------------------------------------------------
# Disabled if empty (no analytics collected)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
