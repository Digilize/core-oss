# ==============================================================================
# Core OSS — Root Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values.
# This file is used by docker-compose.yml.
# Each service also has its own .env.example for running outside Docker.
# ==============================================================================

# ------------------------------------------------------------------------------
# [REQUIRED] Neon DB — shared by all services
# ------------------------------------------------------------------------------
# Format: postgresql://user:password@host/dbname?sslmode=require
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ------------------------------------------------------------------------------
# [REQUIRED] Auth Service (core-auth / better-auth)
# ------------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# Internal secret for core-auth → core-api service calls
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=change-me-generate-with-openssl-rand-hex-32

# Public URLs (used for CORS and redirects)
BETTER_AUTH_URL=http://localhost:3001
CORE_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# ------------------------------------------------------------------------------
# [REQUIRED] Frontend (Vite)
# ------------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000/api
VITE_AUTH_URL=http://localhost:3001

# ------------------------------------------------------------------------------
# [OPTIONAL] AI Providers — at least one needed for /api/chat
# ------------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ------------------------------------------------------------------------------
# [OPTIONAL] Cloudflare R2 — file uploads and document storage
# ------------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=core-os-files
R2_S3_API=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=

# ------------------------------------------------------------------------------
# [OPTIONAL] Image Proxy — Cloudflare Worker for image resizing
# ------------------------------------------------------------------------------
IMAGE_PROXY_SECRET=
IMAGE_PROXY_URL=

# ------------------------------------------------------------------------------
# [OPTIONAL] Resend — workspace invitation emails
# ------------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_DOMAIN=
RESEND_FROM_EMAIL=

# ------------------------------------------------------------------------------
# [OPTIONAL] Exa — web search in AI chat
# ------------------------------------------------------------------------------
EXA_API_KEY=

# ------------------------------------------------------------------------------
# [OPTIONAL] Sentry — error tracking (frontend)
# ------------------------------------------------------------------------------
VITE_SENTRY_DSN=

# ------------------------------------------------------------------------------
# [OPTIONAL] PostHog — analytics (frontend)
# ------------------------------------------------------------------------------
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

# ------------------------------------------------------------------------------
# Environment
# ------------------------------------------------------------------------------
NODE_ENV=development
API_ENV=development
DEBUG=false
